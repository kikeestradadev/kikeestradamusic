section(class="main-container border border-[steelblue]") 
	div(class="container border border-[tomato]") 
		h2(class="text-4xl font-bold mb-6 text-gray-900 dark:text-white") Colores
		
		p(class="text-gray-700 dark:text-gray-300 mb-4") Esta guía define el concepto visual, patrones de diseño y estructura para proyectos web en EDteam.
		
		p(class="text-gray-700 dark:text-gray-300 mb-4") Esta guía se encuentra en constante actualización.
		
		p(class="text-gray-700 dark:text-gray-300 mb-6") Tabla de colores:
		
		//- Ejemplos de uso
		div(class="bg-gray-100 dark:bg-gray-800 rounded-lg p-6 mb-8")
			h3(class="text-xl font-bold mb-4 text-gray-900 dark:text-white") Cómo usar los colores:
			div(class="grid grid-cols-1 m:grid-cols-2 gap-6")
				div
					h4(class="text-lg font-semibold mb-2 text-gray-900 dark:text-white") En Sass/SCSS:
					pre(class="rounded-lg")
						code(class="language-scss").
							.mi-clase {
							  background-color: $firstColor;
							  color: $secondColor;
							}
				div
					h4(class="text-lg font-semibold mb-2 text-gray-900 dark:text-white") En CSS:
					pre(class="rounded-lg")
						code(class="language-css").
							.mi-clase {
							  background-color: var(--first-color);
							  color: var(--second-color);
							}
				div
					h4(class="text-lg font-semibold mb-2 text-gray-900 dark:text-white") En Tailwind:
					pre(class="rounded-lg")
						code(class="language-markup").
							&lt;div class="bg-[var(--first-color)] text-white"&gt;
							  Contenido
							&lt;/div&gt;
		
		//- Grid de colores
		div(class="grid grid-cols-1 sm:grid-cols-2 m:grid-cols-3 gap-6")
			
			//- Principal
			div(class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden")
				div(class="h-48 bg-[#007BDF]")
				div(class="p-6")
					h3(class="text-xl font-bold text-center mb-2 text-gray-900 dark:text-white") Principal
					p(class="text-center text-gray-600 dark:text-gray-400 mb-4") #007BDF
					div(class="space-y-2 text-sm")
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") Sass name: 
							span(class="font-mono text-red-500") $firstColor
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") CSS name: 
							span(class="font-mono text-blue-500") --first-color
			
			//- Principal Alt
			div(class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden")
				div(class="h-48 bg-[#006DC6]")
				div(class="p-6")
					h3(class="text-xl font-bold text-center mb-2 text-gray-900 dark:text-white") Principal Alt
					p(class="text-center text-gray-600 dark:text-gray-400 mb-4") #006DC6
					div(class="space-y-2 text-sm")
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") Sass name: 
							span(class="font-mono text-red-500") $firstColorAlt
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") CSS name: 
							span(class="font-mono text-blue-500") --first-color-alt
			
			//- Secundario
			div(class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden")
				div(class="h-48 bg-[#00CBFF]")
				div(class="p-6")
					h3(class="text-xl font-bold text-center mb-2 text-gray-900 dark:text-white") Secundario
					p(class="text-center text-gray-600 dark:text-gray-400 mb-4") #00CBFF
					div(class="space-y-2 text-sm")
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") Sass name: 
							span(class="font-mono text-red-500") $secondColor
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") CSS name: 
							span(class="font-mono text-blue-500") --second-color
			
			//- Secundario Alt
			div(class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden")
				div(class="h-48 bg-[#00BFF0]")
				div(class="p-6")
					h3(class="text-xl font-bold text-center mb-2 text-gray-900 dark:text-white") Secundario Alt
					p(class="text-center text-gray-600 dark:text-gray-400 mb-4") #00BFF0
					div(class="space-y-2 text-sm")
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") Sass name: 
							span(class="font-mono text-red-500") $secondColorAlt
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") CSS name: 
							span(class="font-mono text-blue-500") --second-color-alt
			
			//- Terciario
			div(class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden")
				div(class="h-48 bg-[#FF3C32]")
				div(class="p-6")
					h3(class="text-xl font-bold text-center mb-2 text-gray-900 dark:text-white") Terciario
					p(class="text-center text-gray-600 dark:text-gray-400 mb-4") #FF3C32
					div(class="space-y-2 text-sm")
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") Sass name: 
							span(class="font-mono text-red-500") $thirdColor
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") CSS name: 
							span(class="font-mono text-blue-500") --third-color
			
			//- Terciario Alt
			div(class="bg-white dark:bg-gray-800 rounded-lg shadow-md overflow-hidden")
				div(class="h-48 bg-[#FF2419]")
				div(class="p-6")
					h3(class="text-xl font-bold text-center mb-2 text-gray-900 dark:text-white") Terciario Alt
					p(class="text-center text-gray-600 dark:text-gray-400 mb-4") #FF2419
					div(class="space-y-2 text-sm")
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") Sass name: 
							span(class="font-mono text-red-500") $thirdColorAlt
						p(class="text-gray-700 dark:text-gray-300")
							span(class="font-semibold") CSS name: 
							span(class="font-mono text-blue-500") --third-color-alt
