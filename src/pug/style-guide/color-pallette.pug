							code(class='ml-2 bg-gray-100 px-1 rounded text-red-500') --second-color
				article(class='rounded bg-white shadow-md overflow-hidden')
					div(class='h-32' style='background-color: #00BFF0;')
					div(class='p-4 text-center')
						h3(class='font-bold text-[22px]') Secundario Alt
