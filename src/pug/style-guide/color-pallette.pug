section(class="main-container border border-[steelblue]")
	div(class="container border border-[tomato]")
		div(class='py-8')
			p(class='text-[18px] l:text-[22px] font-bold mb-6') Tabla de colores:
			div(class='grid grid-cols-1 sm:grid-cols-2 l:grid-cols-3 lg:grid-cols-4 xxl:grid-cols-5 gap-5')
				article(class='rounded bg-white shadow-md overflow-hidden')
					div(class='h-32' style='background-color: #007BDF;')
					div(class='p-4 text-center')
						h3(class='font-bold text-[22px]') Principal
						p(class='text-[18px] text-gray-500 mb-3') #007BDF
						p(class='text-[16px]') Sass name:
							code(class='ml-2 bg-gray-100 px-1 rounded text-red-500') $firstColor
						p(class='text-[16px]') CSS name:
							code(class='ml-2 bg-gray-100 px-1 rounded text-red-500') --first-color
				article(class='rounded bg-white shadow-md overflow-hidden')
					div(class='h-32' style='background-color: #006DC6;')
					div(class='p-4 text-center')
						h3(class='font-bold text-[22px]') Principal Alt
						p(class='text-[18px] text-gray-500 mb-3') #006DC6
						p(class='text-[16px]') Sass name:
							code(class='ml-2 bg-gray-100 px-1 rounded text-red-500') $firstColorAlt
						p(class='text-[16px]') CSS name:
							code(class='ml-2 bg-gray-100 px-1 rounded text-red-500') --first-color-alt
				article(class='rounded bg-white shadow-md overflow-hidden')
					div(class='h-32' style='background-color: #00CBFF;')
					div(class='p-4 text-center')
