//- Bandas y proyectos — carrusel Swiper en mobile, grid en desktop
-
	const bandProjects = [
		{ name: 'Nombre de Banda 1', role: 'Guitarrista / Vocalista', year: '2018 – 2022', img: 'https://placehold.co/400x300/1a1a1a/d4a853?text=Banda+1' },
		{ name: 'Proyecto Colaborativo 2', role: 'Arreglista / Productor', year: '2020 – presente', img: 'https://placehold.co/400x300/1a1a1a/d4a853?text=Proyecto+2' },
		{ name: 'Banda Acústica 3', role: 'Cantante / Guitarrista', year: '2015 – 2019', img: 'https://placehold.co/400x300/1a1a1a/d4a853?text=Banda+3' },
		{ name: 'Sesión de Estudio 4', role: 'Productor musical', year: '2023', img: 'https://placehold.co/400x300/1a1a1a/d4a853?text=Proyecto+4' },
	]

mixin bandCard(project)
	article.band-card
		.band-card__image-wrap
			img.band-card__image(
				src=project.img
				alt=project.name
				loading="lazy"
			)
		div.band-card__body
			h3.band-card__title= project.name
			p.band-card__role= project.role
			p.band-card__year= project.year

section#bandas.bands-section
	.container
		.bands-section__header
			h2.bands-section__title Bandas y proyectos
			div.bands-section__divider
			p.bands-section__desc Una selección de bandas, colaboraciones y proyectos musicales en los que he participado.

		//- Mobile: Swiper
		.bands-swiper-wrap
			.swiper.bands-swiper
				.swiper-wrapper
					each project in bandProjects
						.swiper-slide
							+bandCard(project)
				.bands-swiper__pagination.swiper-pagination

		//- Desktop: grid
		.bands-grid
			each project in bandProjects
				+bandCard(project)
