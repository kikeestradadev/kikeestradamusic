//- Bandas y proyectos — grid de tarjetas con placeholders
section#bandas(class="border-t border-stage-border bg-stage-light py-20 lg:py-28")
	.container
		.text-center
			h2(class="font-display text-3xl font-bold text-white sm:text-4xl") Bandas y proyectos
			div(class="mx-auto mt-2 h-1 w-16 rounded-full bg-accent")
			p(class="mx-auto mt-4 max-w-2xl text-zinc-400") Una selección de bandas, colaboraciones y proyectos musicales en los que he participado.

		.grid(class="mt-12 grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4")
			each project in [{name: 'Nombre de Banda 1', role: 'Guitarrista / Vocalista', year: '2018 – 2022', img: 'https://placehold.co/400x300/1a1a1a/d4a853?text=Banda+1'}, {name: 'Proyecto Colaborativo 2', role: 'Arreglista / Productor', year: '2020 – presente', img: 'https://placehold.co/400x300/1a1a1a/d4a853?text=Proyecto+2'}, {name: 'Banda Acústica 3', role: 'Cantante / Guitarrista', year: '2015 – 2019', img: 'https://placehold.co/400x300/1a1a1a/d4a853?text=Banda+3'}, {name: 'Sesión de Estudio 4', role: 'Productor musical', year: '2023', img: 'https://placehold.co/400x300/1a1a1a/d4a853?text=Proyecto+4'}]
				article(class="group overflow-hidden rounded-xl border border-stage-border bg-stage transition-all duration-300 hover:-translate-y-1 hover:border-accent/40 hover:shadow-xl hover:shadow-accent/5")
					//- Reemplazar img con foto real del proyecto
					.overflow-hidden
						img(
							src=project.img
							alt=project.name
							class="aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105"
							loading="lazy"
						)
					div(class="p-5")
						h3(class="font-display text-lg font-semibold text-white")= project.name
						p(class="mt-1 text-sm text-accent")= project.role
						p(class="mt-2 text-xs text-zinc-500")= project.year
