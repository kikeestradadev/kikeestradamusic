//- Formulario de contacto (Web3Forms — https://web3forms.com)
section#contacto(class="border-t border-stage-border bg-stage-light py-20 lg:py-28")
	.container
		.text-center
			h2(class="font-display text-3xl font-bold text-white sm:text-4xl") Contacto
			div(class="mx-auto mt-2 h-1 w-16 rounded-full bg-accent")
			p(class="mx-auto mt-4 max-w-2xl text-zinc-400") ¿Tienes un proyecto musical? Escríbeme y conversemos.

		.mx-auto(class="mt-12 max-w-xl")
			form#contact-form(class="space-y-4" novalidate)
				//- Honeypot anti-spam (Web3Forms)
				input(type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off")

				div
					label(for="contact-name" class="mb-1.5 block text-sm font-medium text-zinc-400") Nombre
					input#contact-name(
						type="text"
						name="name"
						required
						autocomplete="name"
						placeholder="Tu nombre"
						class="w-full rounded-lg border border-stage-border bg-stage px-4 py-3 text-zinc-300 placeholder-zinc-600 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
					)
				div
					label(for="contact-email" class="mb-1.5 block text-sm font-medium text-zinc-400") Email
					input#contact-email(
						type="email"
						name="email"
						required
						autocomplete="email"
						placeholder="tu@email.com"
						class="w-full rounded-lg border border-stage-border bg-stage px-4 py-3 text-zinc-300 placeholder-zinc-600 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
					)
				div
					label(for="contact-message" class="mb-1.5 block text-sm font-medium text-zinc-400") Mensaje
					textarea#contact-message(
						name="message"
						rows="5"
						required
						placeholder="Cuéntame sobre tu proyecto..."
						class="w-full resize-none rounded-lg border border-stage-border bg-stage px-4 py-3 text-zinc-300 placeholder-zinc-600 transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
					)

				p#contact-status.contact-status(hidden role="status" aria-live="polite")

				div(class="text-center sm:text-left")
					button#contact-submit(
						type="submit"
						class="w-full rounded-lg bg-accent px-8 py-3.5 text-sm font-semibold uppercase tracking-wider text-stage transition-all hover:bg-accent-light sm:w-auto"
					) Enviar mensaje
