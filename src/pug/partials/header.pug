//- Header / Nav fijo (solo barra superior)
header.site-header#header
	nav.site-nav.container(aria-label="Navegación principal")
		a.site-nav__logo(href="#inicio" aria-label="Kike Estrada — Inicio")
			span Kike Estrada

		ul.site-nav__desktop(role="list")
			each item in [{href: '#inicio', label: 'Inicio'}, {href: '#bio', label: 'Bio'}, {href: '#bandas', label: 'Bandas'}, {href: '#discografia', label: 'Discografía'}, {href: '#musica', label: 'Música'}, {href: '#galeria', label: 'Galería'}, {href: '#', label: 'Contacto', trigger: true}]
				li
					if item.trigger
						a.site-nav__link.contact-trigger(href="#")= item.label
					else
						a.site-nav__link(href=item.href)= item.label

		button#nav-toggle.site-nav__toggle(type="button" aria-expanded="false" aria-controls="nav-menu" aria-label="Abrir menú")
			span.nav-bar
			span.nav-bar
			span.nav-bar
