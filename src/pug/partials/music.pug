//- Música — embeds de Spotify y YouTube
section#musica(class="border-t border-stage-border bg-stage-light py-20 lg:py-28")
	.container
		.text-center
			h2(class="font-display text-3xl font-bold text-white sm:text-4xl") Música
			div(class="mx-auto mt-2 h-1 w-16 rounded-full bg-accent")
			p(class="mx-auto mt-4 max-w-2xl text-zinc-400") Escucha mis últimos lanzamientos y colaboraciones.

		.grid(class="mt-12 grid-cols-1 gap-8 lg:grid-cols-2")
			//- Spotify embed — reemplazar src con URL real del artista/playlist
			.embed-wrapper(class="overflow-hidden rounded-xl border border-stage-border bg-stage")
				iframe(
					src="https://open.spotify.com/embed/track/4cOdK8wJEeNp3wr2mFhF82?utm_source=generator&theme=0"
					width="100%"
					height="352"
					frameBorder="0"
					allowfullscreen=""
					allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
					loading="lazy"
					title="Spotify — Kike Estrada"
					class="w-full"
				)

			//- YouTube embed — reemplazar src con video real
			.embed-wrapper(class="overflow-hidden rounded-xl border border-stage-border bg-stage")
				.relative(class="aspect-video")
					iframe(
						src="https://www.youtube.com/embed/dQw4w9WgXcQ"
						width="100%"
						height="100%"
						frameBorder="0"
						allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
						allowfullscreen=""
						loading="lazy"
						title="YouTube — Kike Estrada"
						class="absolute inset-0 h-full w-full"
					)

		//- Segundo embed (Spotify playlist o álbum)
		.mt-8
			.embed-wrapper(class="mx-auto max-w-2xl overflow-hidden rounded-xl border border-stage-border bg-stage")
				iframe(
					src="https://open.spotify.com/embed/album/1ATL5GLyefJaxhQzSPVrWl?utm_source=generator&theme=0"
					width="100%"
					height="152"
					frameBorder="0"
					allowfullscreen=""
					allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
					loading="lazy"
					title="Spotify Playlist — Kike Estrada"
					class="w-full"
				)
