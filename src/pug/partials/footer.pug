//- Footer — layout centrado y equilibrado
footer.site-footer(class="border-t border-stage-border bg-stage")
	.container.site-footer__inner
		p.site-footer__brand(class="font-display text-2xl font-bold text-white") Kike Estrada

		nav.site-footer__nav(aria-label="Links rápidos")
			ul.footer-nav(role="list")
				each link in [{href: '#inicio', label: 'Inicio'}, {href: '#bio', label: 'Bio'}, {href: '#bandas', label: 'Bandas'}, {href: '#discografia', label: 'Discografía'}, {href: '#musica', label: 'Música'}, {href: '#galeria', label: 'Galería'}, {href: '#', label: 'Contacto', trigger: true}]
					li
						if link.trigger
							a.contact-trigger(href="#")= link.label
						else
							a(href=link.href)= link.label

		div.site-footer__social(aria-label="Redes sociales")
			-socialClasses = "justify-center gap-4"
			include social-links

		div.site-footer__divider

		p.site-footer__copy
			| © 
			span#footer-year 2026
			|  Kike Estrada. Todos los derechos reservados.

		p.site-footer__tagline Costa Rica · Cantante · Guitarrista · Arreglista · Productor
