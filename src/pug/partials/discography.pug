//- Producciones / Discografía
section#discografia(class="py-20 lg:py-28")
	.container
		.text-center
			h2(class="font-display text-3xl font-bold text-white sm:text-4xl") Discografía
			div(class="mx-auto mt-2 h-1 w-16 rounded-full bg-accent")
			p(class="mx-auto mt-4 max-w-2xl text-zinc-400") Trabajos producidos, grabados y en los que he colaborado como músico o productor.

		.grid(class="mt-12 grid-cols-2 gap-4 sm:grid-cols-3 sm:gap-6 lg:grid-cols-4")
			each album in [{title: 'Álbum / EP 1', year: '2024', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Album+1'}, {title: 'Single 2', year: '2023', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Single+2'}, {title: 'Colaboración 3', year: '2022', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Album+3'}, {title: 'Producción 4', year: '2021', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Album+4'}, {title: 'En vivo 5', year: '2020', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Album+5'}, {title: 'Demo 6', year: '2019', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Album+6'}]
				article(class="group text-center")
					//- Reemplazar con carátula real
					.overflow-hidden(class="rounded-xl")
						img(
							src=album.img
							alt=`Carátula — ${album.title}`
							class="aspect-square w-full object-cover transition-transform duration-500 group-hover:scale-105"
							loading="lazy"
						)
					h3(class="mt-3 font-display text-sm font-semibold text-white sm:text-base")= album.title
					p(class="mt-1 text-xs text-zinc-500 sm:text-sm")= album.year
