//- Discografía — carrusel Swiper en mobile, grid en desktop
-
	const albums = [
		{ title: 'Álbum / EP 1', year: '2024', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Album+1' },
		{ title: 'Single 2', year: '2023', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Single+2' },
		{ title: 'Colaboración 3', year: '2022', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Album+3' },
		{ title: 'Producción 4', year: '2021', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Album+4' },
		{ title: 'En vivo 5', year: '2020', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Album+5' },
		{ title: 'Demo 6', year: '2019', img: 'https://placehold.co/400x400/1a1a1a/d4a853?text=Album+6' },
	]

mixin albumCard(album)
	article.discography-card
		.discography-card__cover-wrap
			img.discography-card__cover(
				src=album.img
				alt=`Carátula — ${album.title}`
				loading="lazy"
			)
		h3.discography-card__title= album.title
		p.discography-card__year= album.year

section#discografia.discography-section
	.container
		.discography-section__header
			h2.discography-section__title Discografía
			div.discography-section__divider
			p.discography-section__desc Trabajos producidos, grabados y en los que he colaborado como músico o productor.

		//- Mobile: Swiper
		.discography-swiper-wrap
			.swiper.discography-swiper
				.swiper-wrapper
					each album in albums
						.swiper-slide
							+albumCard(album)
				.discography-swiper__pagination.swiper-pagination

		//- Desktop: grid
		.discography-grid
			each album in albums
				+albumCard(album)
