block config
	-let currentPage 		= 'home'
	-let content 			= 'My Page'
	-let siteName 			= 'Kike Estrada'
	-let pageDescription 	= ''
	-let pageTitle 			= ''
	-let pageKeywords 		= ''
	-let locale 			= 'es'
include ../data/site-data
-
	var seoLocale = siteData[locale] || siteData.es
	var seoTitle = pageTitle || seoLocale.title
	var seoDescription = pageDescription || seoLocale.description
	var seoKeywords = pageKeywords || seoLocale.keywords
	var seoCanonical = locale === 'en'
		? siteData.siteUrl + '/en.html'
		: siteData.siteUrl + '/'
	var seoOgImageAlt = (siteData.ogImageAlt && siteData.ogImageAlt[locale]) || siteData.ogImageAlt.es
doctype html
html(lang=locale prefix='og: http://ogp.me/ns#', class='no-js')
	head
		meta(charset="utf-8")
		meta(name="viewport", content="width=device-width, initial-scale=1.0")
		meta(name='format-detection', content='telephone=no')
		meta(name="theme-color", content="#000000")
		meta(name="author", content=siteData.author)
		meta(name="robots", content="index, follow")
		link(rel="shortcut icon", type="image/png", href="./assets/img/icon_1024.png")
		link(rel="apple-touch-icon", href="./assets/img/icon_1024.png")
		title= seoTitle
		meta(name="description", content=seoDescription)
		meta(name="keywords", content=seoKeywords)
		link(rel="canonical", href=seoCanonical)
		link(rel="alternate" hreflang="es" href=siteData.siteUrl + '/')
		link(rel="alternate" hreflang="en" href=siteData.siteUrl + '/en.html')
		link(rel="alternate" hreflang="x-default" href=siteData.siteUrl + '/')
		meta(property="og:type", content="website")
		meta(property="og:site_name", content=siteData.siteName)
		meta(property="og:title", content=seoTitle)
		meta(property="og:description", content=seoDescription)
		meta(property="og:url", content=seoCanonical)
		meta(property="og:image", content=siteData.ogImage)
		meta(property="og:image:alt", content=seoOgImageAlt)
		meta(property="og:locale", content=seoLocale.ogLocale)
		meta(property="og:locale:alternate", content=seoLocale.ogLocaleAlternate)
		meta(name="twitter:card", content="summary_large_image")
		meta(name="twitter:title", content=seoTitle)
		meta(name="twitter:description", content=seoDescription)
		meta(name="twitter:image", content=siteData.ogImage)
		meta(http-equiv="Content-Security-Policy", content="upgrade-insecure-requests")
		meta(http-equiv="Cache-Control", content="no-cache, no-store, must-revalidate")
		meta(http-equiv="Expires", content="0")
		meta(http-equiv="Pragma", content="no-cache")
		link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css")
		link(rel="preconnect" href="https://fonts.googleapis.com")
		link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
		link(href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet")
		link(rel="stylesheet" href="./assets/prism.css")
		link(rel="stylesheet" href=`styles.css?v=${siteData.assetVersion}`)
	body(class=`${currentPage} locale-${locale}`, itemscope itemtype="http://schema.org/WebPage")
		//- here start the Main Header
		header(class='main-header')
			block main-header
		//- here ends the Main Header
		//- here start the Main Container
		main(class='main-container')
			block main-container
		//- here ends the Main Container
		//- here start the Main Footer
		footer(class='main-footer')
			block main-footer
		//- here ends the Main Footer
		script(src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js")
		script(src=`index.js?v=${siteData.assetVersion}`)
		block scripts
