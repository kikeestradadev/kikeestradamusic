block config
	-let currentPage 		= 'home'
	-let content 			= 'My Page'
	-let siteName 			= 'Kike Estrada'
	-let pageDescription 	= 'Cantante y músico. Landing page oficial.'
	-let locale 			= 'es'
include ../data/site-data
doctype html
html(lang=locale prefix='og: http://ogp.me/ns#', class='no-js')
	head
		meta(charset="utf-8")
		meta(name="viewport", content="width=device-width, initial-scale=1.0")
		meta(name='format-detection', content='telephone=no')
		meta(name="theme-color", content="#000000")
		link(rel="shortcut icon", type="image/png", href="./assets/img/icon_1024.png")
		link(rel="apple-touch-icon", href="./assets/img/icon_1024.png")
		meta(name="description", content=pageDescription)
		link(rel="alternate" hreflang="es" href="./index.html")
		link(rel="alternate" hreflang="en" href="./en.html")
		link(rel="alternate" hreflang="x-default" href="./index.html")
		meta(http-equiv="Content-Security-Policy", content="upgrade-insecure-requests")
		meta(http-equiv="Cache-Control", content="no-cache, no-store, must-revalidate")
		meta(http-equiv="Expires", content="0")
		meta(http-equiv="Pragma", content="no-cache")
		link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css")
		link(rel="preconnect" href="https://fonts.googleapis.com")
		link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
		link(href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet")
		link(rel="stylesheet" href="./assets/prism.css")
		link(rel="stylesheet" href=`styles.css?v=${siteData.assetVersion}`)
		title= currentPage.slice(0,1).toUpperCase() + currentPage.slice(1) + " | " + siteName
	body(class=`${currentPage} locale-${locale}`, itemscope itemtype="http://schema.org/WebPage")
		//- here start the Main Header
		header(class='main-header')
			block main-header
		//- here ends the Main Header
		//- here start the Main Container
		main(class='main-container')
			block main-container
		//- here ends the Main Container
		//- here start the Main Footer
		footer(class='main-footer')
			block main-footer
		//- here ends the Main Footer
		include ../modules/floating-button
		script(src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js")
		script(src=`index.js?v=${siteData.assetVersion}`)
		block scripts
