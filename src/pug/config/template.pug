block config
	-let currentPage 		= 'home'
	-let pageTitle 			= 'Portafolio Musical'
	-let siteName 			= 'Kike Estrada'
	-let pageDescription 	= 'Kike Estrada — Cantante, guitarrista, arreglista y productor musical de Costa Rica.'
	-let siteUrl 			= 'https://kikeestradadev.github.io/kikeestradamusic/'
	-let ogImage 			= 'https://placehold.co/1200x630/0d0d0d/d4a853?text=Kike+Estrada'
doctype html
html(lang='es' class='scroll-smooth')
	head
		include head
	body(class=`${currentPage} bg-stage text-zinc-300 font-sans antialiased`, itemscope itemtype="http://schema.org/WebPage")
		block main-header
		main
			block main-container
		block main-footer
		include ../partials/whatsapp-sticky
		//- Lightbox overlay (galería)
		#lightbox(class="fixed inset-0 z-[9999] hidden items-center justify-center bg-black/95 p-4" role="dialog" aria-modal="true" aria-label="Visor de imagen")
			button#lightbox-close(type="button" class="absolute top-4 right-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-stage-light text-zinc-300 transition-colors hover:bg-accent hover:text-stage" aria-label="Cerrar")
				svg(class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24")
					path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12")
			button#lightbox-prev(type="button" class="absolute left-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-stage-light text-zinc-300 transition-colors hover:bg-accent hover:text-stage max-sm:hidden" aria-label="Imagen anterior")
				svg(class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24")
					path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7")
			button#lightbox-next(type="button" class="absolute right-4 z-10 flex h-10 w-10 items-center justify-center rounded-full bg-stage-light text-zinc-300 transition-colors hover:bg-accent hover:text-stage max-sm:hidden" aria-label="Imagen siguiente")
				svg(class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24")
					path(stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7")
			img#lightbox-img(src="" alt="" class="max-h-[85vh] max-w-full rounded-lg object-contain shadow-2xl")
		script(src="./index-dist.js")
		block scripts
