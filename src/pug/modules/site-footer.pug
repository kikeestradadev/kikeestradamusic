include ../data/site-footer-data

div(class='site-footer' id=siteFooterData.id)
	div(class='container site-footer__container')
		p(class='site-footer__brand')= siteFooterData.brand
		nav(class='site-footer__nav' aria-label=siteFooterData.navLabel)
			ul(class='site-footer__list')
				each item in siteFooterData.items
					li(class='site-footer__item')
						a(class='site-footer__link' href=item.href)= item.label
		div(class='site-footer__langs' role='navigation' aria-label=siteFooterData.langsLabel)
			each lang in siteFooterData.languages
				a(
					class=`site-footer__lang${lang.code === locale ? ' site-footer__lang--active' : ''}`
					href=lang.href
					hreflang=lang.code
					lang=lang.code
					aria-current=(lang.code === locale ? 'page' : false)
				)= lang.label
		ul(class='site-footer__socials')
			each social in siteFooterData.socials
				li(class='site-footer__social-item')
					a(class='site-footer__social-link' href=social.href target='_blank' rel='noopener noreferrer' aria-label=social.label)
						if social.icon === 'spotify'
							svg(class='site-footer__social-icon' viewBox='0 0 24 24' aria-hidden='true')
								path(fill='currentColor' d='M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.52 17.34c-.24.36-.66.48-1.02.24-2.82-1.74-6.36-2.1-10.56-1.14-.42.12-.78-.18-.9-.54-.12-.42.18-.78.54-.9 4.56-1.02 8.52-.6 11.64 1.32.42.18.48.66.3 1.02zm1.44-3.18c-.3.42-.84.6-1.26.3-3.24-1.98-8.16-2.58-11.94-1.38-.48.12-1.02-.12-1.14-.66-.12-.48.12-1.02.66-1.14 4.38-1.32 9.78-.66 13.5 1.62.42.24.54.84.18 1.26zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.3c-.6.18-1.2-.18-1.38-.72-.18-.6.18-1.2.72-1.38 4.26-1.26 11.28-1.02 15.72 1.62.54.3.72 1.02.42 1.56-.3.48-1.02.66-1.56.42z')
						else if social.icon === 'tiktok'
							svg(class='site-footer__social-icon' viewBox='0 0 24 24' aria-hidden='true')
								path(fill='currentColor' d='M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.3 0 .59.04.87.13V9.01a6.27 6.27 0 0 0-.87-.06A6.33 6.33 0 0 0 3.16 15.3a6.33 6.33 0 0 0 6.33 6.33 6.33 6.33 0 0 0 6.33-6.33V9.18a8.16 8.16 0 0 0 4.77 1.52V7.25a4.85 4.85 0 0 1-1-.56z')
		p(class='site-footer__copyright')= siteFooterData.copyright
